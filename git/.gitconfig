[user]
	name = gogongxt
	email = gogongxt@163.com
[pull]
	rebase = true
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[core]
	excludesFile = ~/.gitignore_global
[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[delta]
	dark = true
	wrap-max-lines = unlimited
	minus-style = "#E78284" "#4A2E32"
	plus-style = syntax "#496F4A"
	minus-emph-style = "#ff0000" "#cccccc" bold
	plus-emph-style = "#ff0000" "#cccccc" bold
