{
  "permissions": {
    "allow": [
      "Read(/)",
      "Bash(npm run test *)",
      "Bash(ls *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(sed *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(sudo *)",
      "Bash(chown *)",
      "Bash(git add *)",
      "Bash(git reset *)",
      "Bash(git restore --staged *)",
      "Bash(git rm *)",
      "Bash(git branch -D *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker system prune *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccsp@latest"
  },
  "enabledPlugins": {
    "sentry-skills@sentry-skills": true
  },
  "extraKnownMarketplaces": {
    "sentry-skills": {
      "source": {
        "source": "github",
        "repo": "getsentry/skills"
      }
    }
  },
  "skipWebFetchPreflight": true,
  "syntaxHighlightingDisabled": true,
  "alwaysThinkingEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/notify.sh stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/notify.sh notification \"$CLAUDE_NOTIFICATION_TEXT\""
          }
        ]
      }
    ]
  }
}
